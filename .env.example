APP_NAME=Hyperliquid Research Platform
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hyperliquid_research
AUTO_CREATE_TABLES=false
PAPER_TRADING=true
TRADING_MODE=paper
INITIAL_EQUITY=10000
MAX_RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
MAX_LEVERAGE=3
MAX_SIMULTANEOUS_TRADES=3
PAPER_FEE_RATE=0.00045
HYPERLIQUID_BASE_URL=https://api.hyperliquid-testnet.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid-testnet.xyz/ws
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
FEAR_GREED_URL=https://api.alternative.me/fng/
DYDX_INDEXER_URL=https://indexer.v4testnet.dydx.exchange/v4
DYDX_WALLET_ADDRESS=
DYDX_SUBACCOUNT_NUMBER=0
DYDX_ENABLE_TESTNET_EXECUTION=false
DYDX_TEST_MNEMONIC=
DYDX_FIXED_BTC_SIZE=0.0005
DYDX_MAX_ACCOUNT_RISK=0.0025
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_NEWS_MODEL=gemini-3.1-flash-lite
GEMINI_MARKET_MODEL=gemini-3.5-flash
GEMINI_DECISION_MODEL=gemini-3.5-flash
DECISION_SCHEDULER_ENABLED=true
DECISION_SCHEDULER_SYMBOL=BTC
DECISION_SCHEDULER_INTERVAL_SECONDS=900
PAPER_TRADE_MONITOR_ENABLED=true
PAPER_TRADE_MONITOR_INTERVAL_SECONDS=60
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_COMMAND_POLLING_ENABLED=true
TELEGRAM_COMMAND_POLLING_INTERVAL_SECONDS=3
TELEGRAM_WEBHOOK_URL=
TELEGRAM_CHANNEL_USERNAMES=[]
REDDIT_COMMUNITIES=["CryptoCurrency","Bitcoin","ethereum","CryptoMarkets"]
LOG_LEVEL=INFO
